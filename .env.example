# Postgres (Neon — auto-provisioned by the Vercel Marketplace integration)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Single password protecting /dashboard via HTTP Basic Auth.
# Browser will prompt for a username; type anything, the username is ignored.
TREFLY_ADMIN_PASSWORD=pick-a-strong-password

# Long random string used to derive the daily visitor-hash salt.
# Generate with: openssl rand -hex 32
TREFLY_HASH_SECRET=replace-me-with-32-bytes-of-randomness
