# Postgres (Neon — auto-provisioned by the Vercel Marketplace integration)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Clerk (Vercel Marketplace integration)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
# Set to /sign-in / /sign-up so Clerk's components route correctly
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard
# Optional: where Clerk sends the user after sign-out
# NEXT_PUBLIC_CLERK_AFTER_SIGN_OUT_URL=/

# From the Clerk dashboard → Webhooks (signing secret prefixed with whsec_)
CLERK_WEBHOOK_SECRET=whsec_xxx

# Long random string used to derive the daily visitor-hash salt.
# Generate with: openssl rand -hex 32
TREFLY_HASH_SECRET=replace-me-with-32-bytes-of-randomness
